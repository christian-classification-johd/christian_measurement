library(tidyverse)
library(stringi)
# declaring the file paths for the metadata file, text directory, and the output files
data_path <- "../data/processed_texts"
meta_csv <- file.path(data_path,"latinise_metadata_2026.csv")
texts_dir <- "../data/lemmatized_texts_2026"
corpus_rds  <- file.path(data_path,"corpus_600ad.rds")
corpus_csv  <- file.path(data_path,"corpus_600ad.csv")
# reading in the metadata file as a .csv and standardizing the file name format
meta <- readr::read_csv(meta_csv, show_col_types = FALSE) %>%
mutate(file = basename(as.character(file)))
# defining a function to iteratively tokenize all the files in the folder
read_txt <- function(path){
x <- readr::read_file(path) # reading file content
x <- stri_trans_nfc(x)      # converting text to unicode normalization form
x <- str_replace_all(x, "\\r\\n?", "\n") # standardizing all line breaks to the standard \n
x <- str_squish(x) # getting rid of all white spaces at the end and beginning of texts; also getting rid of double spaces
x
}
# stripping the numbers from the text
strip_hash_nums <- function(x) str_replace_all(x, "#\\d+", "")
# running the regex functions on all the files in our text directory
texts <- tibble(file_full = dir(texts_dir, pattern = "\\.txt$", full.names = TRUE, recursive = TRUE)) %>%
mutate(file = basename(file_full),
text_raw = map_chr(file_full, read_txt),
text     = strip_hash_nums(text_raw))
df <- meta %>%
left_join(select(texts, file, text_raw, text), by = "file") %>% # combining the meta data with each of the text files
mutate(
n_chars_raw = nchar(text_raw, allowNA = TRUE), #counting the number of characters in text files
n_chars     = nchar(text,     allowNA = TRUE),
n_words_raw = if_else(is.na(text_raw), NA_integer_, str_count(text_raw, "(?u)\\p{L}+")), # counting words
n_words     = if_else(is.na(text),     NA_integer_, str_count(text,     "(?u)\\p{L}+"))
)
readr::write_csv(df, corpus_csv)
saveRDS(df, corpus_rds)
print(head(select(df, file, n_chars, n_words)))
# Defining the function to categorize Era based on Date (I know not everyone uses these labels, but it doesn't matter for our purposes what the label names are )
get_latin_era <- function(year) {
if (is.na(year)) { return("Unknown") }
if (year < -80) { return("Archaic") }
else if (year < 14) { return("Classical") }
else if (year < 180) { return("Silver") }
else { return("Late") }
}
# applying the era function to all rows of the df (each row corresponds to a text and its metadata)
df <- df %>%
mutate(era = sapply(date, get_latin_era))
# Defining the function to categorize Era based on Date (I know not everyone uses these labels, but it doesn't matter for our purposes what the label names are )
get_latin_era <- function(year) {
if (is.na(year)) { return("Unknown") }
if (year < -80) { return("Archaic") }
else if (year < 14) { return("Classical") }
else if (year < 180) { return("Silver") }
else { return("Late") }
}
# applying the era function to all rows of the df (each row corresponds to a text and its metadata)
df <- df %>%
mutate(era = sapply(date, get_latin_era))
library(dplyr)
# defining the vectorized era function
get_latin_era <- function(year) {
case_when(
is.na(year) ~ "Unknown",
year < -80  ~ "Archaic",
year < 14   ~ "Classical",
year < 180  ~ "Silver",
TRUE        ~ "Late"
)
}
# mutating the dataframe
df <- df %>%
# applying the logic to the start date
mutate(start_era = get_latin_era(date_range_start)) %>%
# applying the logic to the end date
mutate(end_era = get_latin_era(date_range_end))
# inspecting the results
head(df)
library(dplyr)
# defining the vectorized era function
get_latin_era <- function(year) {
case_when(
is.na(year) ~ "Unknown",
year < -80  ~ "Archaic",
year < 14   ~ "Classical",
year < 180  ~ "Silver",
TRUE        ~ "Late"
)
}
# mutating the dataframe
df <- df %>%
# applying the logic to the start date
mutate(start_era = get_latin_era(date_range_start)) %>%
# applying the logic to the end date
mutate(end_era = get_latin_era(date_range_end))
# inspecting the results
head(df)
# creating a stratum column and making labels by putting together strata+labels (e.g., "Late_prose", "Classical_poetry")
df <- df %>%
mutate(stratum_start = paste(start_era, type, sep = "_")) %>%
# generating the end stratum identifier
mutate(stratum_end = paste(end_era, type, sep = "_"))
print("Distribution of Strata in Full Corpus:")
print(table(df$stratum_start,stratum_end))
print("Distribution of Strata in Full Corpus:")
print(table(df$stratum_start,df$stratum_end))
# Total corpus size = 1246.
# Sampling fraction = 100 / 1246 ≈ 0.08 (8%)
set.seed(42) # Setting seed for reproducibility
sample_df <- df %>%
group_by(stratum_start,stratum_end) %>%
# Sample 8% from each date stratum to maintain the ratio
slice_sample(prop = 100/nrow(df)) %>% # defining a sample of 100 texts (this can be changed to any number)
ungroup()
print(paste(nrow(sample_df)))
library(tidytext)
# Extracting the top N words to act as the fingerprint
get_top_words <- function(df, n = 50) {
df %>%
unnest_tokens(word, text) %>%
count(word, sort = TRUE) %>%
slice_max(n = n, order_by = n) %>%
pull(word)
}
# running the function to get the top words
target_words <- get_top_words(df)
# Defining function to calculate relative frequency of specific words
get_fingerprint <- function(data, text_col, target_words) {
# Collapsing all text into one giant string & tokenizing
all_text <- paste(data[[text_col]], collapse = " ")
# making all text lowercase (might wanna revisit this; I know there is deus and Deus etc.)
all_text <- str_to_lower(all_text)
# splitting the entire corpus by non-word characters
all_words <- unlist(str_split(all_text, "\\W+"))
# counting total number of words
total_count <- length(all_words)
# 3. calculating relative frequency as a percentage for target words in the corpus
results <- numeric(length(target_words))
names(results) <- target_words
for (word in target_words) {
word_count <- sum(all_words == word)
results[word] <- (word_count / total_count) * 100
}
return(results)
}
# Running the test on both datasets to ensure that our sample is representative
corpus_stats <- get_fingerprint(df, "text_raw", target_words)
sample_stats <- get_fingerprint(sample_df, "text_raw", target_words)
library(knitr)
library(tidytext)
# Aggregating word percentages for comparison
word_comp <- data.frame(
Word = names(corpus_stats),
Corpus_Pct = as.numeric(corpus_stats),
Sample_Pct = as.numeric(sample_stats)
)
# Aggregating Era percentages (just for the table view)
era_comp <- data.frame(
Era = names(prop.table(table(df$era))),
Corpus_Pct = as.numeric(prop.table(table(df$era)) * 100),
Sample_Pct = as.numeric(prop.table(table(sample_df$era)) * 100)
)
# Binding for display
validation_df <- rbind(
data.frame(Feature = paste0("Word: ", word_comp$Word),
Corpus_Pct = word_comp$Corpus_Pct,
Sample_Pct = word_comp$Sample_Pct),
data.frame(Feature = paste0("Era: ", era_comp$Era),
Corpus_Pct = era_comp$Corpus_Pct,
Sample_Pct = era_comp$Sample_Pct)
) %>%
mutate(Diff = abs(Corpus_Pct - Sample_Pct))
