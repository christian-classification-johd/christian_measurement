library(tidyverse)
library(brms)
library(cmdstanr)
library(tidybayes)
library(loo)
library(patchwork)
options(mc.cores = parallel::detectCores())
options(brms.backend = "cmdstanr")
theme_set(theme_classic(base_size = 14))
set.seed(20260330)
path <- "../../data/processed_texts/600ad/corpus_600ad_model_outputs_oof.csv"
dir.create("brms_fits", showWarnings = FALSE, recursive = TRUE)
dir.create("plots", showWarnings = FALSE, recursive = TRUE)
dir.create("model_summaries", showWarnings = FALSE, recursive = TRUE)
dir.create("posterior_summaries", showWarnings = FALSE, recursive = TRUE)
score_cols_target <- c(
"score_nb_logit",
"score_ridge_logit",
"score_svm_logit",
"score_xgb_logit",
"score_lgb_logit"
)
score_labels <- c(
score_nb_logit = "NB",
score_ridge_logit = "Ridge",
score_svm_logit = "SVM",
score_xgb_logit = "XGBoost",
score_lgb_logit = "LightGBM"
)
normalize_label <- function(x) {
x <- tolower(trimws(as.character(x)))
x <- gsub("-", "_", x)
x <- gsub("\\s+", "_", x)
dplyr::case_when(
x %in% c("1", "christian", "c", "yes", "true") ~ "christian",
x %in% c("0", "non_christian", "nonchristian", "non_christ", "non_christian_text", "non christian", "pagan", "no", "false") ~ "non_christian",
TRUE ~ x
)
}
mode_value <- function(x) names(sort(table(x), decreasing = TRUE))[1]
make_imputations <- function(df, M = 20, seed = 20260330) {
set.seed(seed)
lo <- pmin(df$date_range_start, df$date_range_end)
hi <- pmax(df$date_range_start, df$date_range_end)
# Adding a tiny jitter (1e-4) guarantees values aren't perfectly identical, avoiding singular mgcv basis crashes
purrr::map(seq_len(M), ~ dplyr::mutate(df, date_imp = runif(nrow(df), lo, hi + 1e-4)))
}
make_priors <- function(formula, df) {
sy <- stats::sd(df$y, na.rm = TRUE)
my <- mean(df$y, na.rm = TRUE)
sy <- ifelse(is.finite(sy) && sy > 0, sy, 1)
gp <- get_prior(formula = formula, data = df, family = student())
pri <- brms::empty_prior()
# Safely building strings with paste0() to bypass system locale decimal comma bugs
if ("Intercept" %in% gp$class) {
pri <- c(pri, set_prior(paste0("normal(", round(my, 4), ", ", round(2 * sy, 4), ")"), class = "Intercept"))
}
if ("b" %in% gp$class) {
pri <- c(pri, set_prior(paste0("normal(0, ", round(sy, 4), ")"), class = "b"))
}
if ("sds" %in% gp$class) {
pri <- c(pri, set_prior(paste0("normal(0, ", round(sy, 4), ")"), class = "sds"))
}
if ("sd" %in% gp$class) {
pri <- c(pri, set_prior(paste0("normal(0, ", round(sy, 4), ")"), class = "sd"))
}
if ("sigma" %in% gp$class) {
pri <- c(pri, set_prior(paste0("normal(0, ", round(sy, 4), ")"), class = "sigma"))
}
if ("nu" %in% gp$class) {
pri <- c(pri, set_prior("gamma(2, 0.1)", class = "nu"))
}
pri
}
elpd_diff_tbl <- function(loo_a, loo_b, a, b) {
if (is.null(loo_a) || is.null(loo_b)) {
return(tibble(comparison = paste0(a, "_minus_", b), elpd_diff = NA_real_, se_diff = NA_real_))
}
d <- loo_a$pointwise[, "elpd_loo"] - loo_b$pointwise[, "elpd_loo"]
tibble(
comparison = paste0(a, "_minus_", b),
elpd_diff = sum(d),
se_diff = sqrt(length(d) * stats::var(d))
)
}
dat <- readr::read_csv(path, show_col_types = FALSE) %>%
mutate(
manual_label = normalize_label(manual_label),
manual_label = factor(manual_label, levels = c("non_christian", "christian")),
creator = forcats::fct_explicit_na(factor(creator), "Unknown"),
type = forcats::fct_explicit_na(factor(type), "Unknown"),
date_range_start = as.numeric(date_range_start),
date_range_end = as.numeric(date_range_end),
date_mid = (date_range_start + date_range_end) / 2
) %>%
filter(
manual_label %in% c("non_christian", "christian"),
is.finite(date_range_start),
is.finite(date_range_end)
)
score_cols <- intersect(score_cols_target, names(dat))
fit_one_score <- function(score_col, dat, M = 20) {
df <- dat %>%
transmute(
row_id = row_number(),
y = .data[[score_col]],
manual_label,
creator,
type,
date_range_start,
date_range_end,
date_mid
) %>%
filter(is.finite(y)) %>%
droplevels()
if (nrow(df) < 40) stop(paste("Too few rows for", score_col))
if (nlevels(df$manual_label) < 2) stop(paste("Only one manual_label level for", score_col))
# CRITICAL: Compute splines based on the smallest group to prevent singular design matrices
min_class_count <- min(table(df$manual_label))
if (min_class_count < 5) stop(paste("Too few observations in one of the classes for", score_col))
type_ok <- nlevels(df$type) > 1
creator_tab <- table(df$creator)
creator_ok <- nlevels(df$creator) > 1 && any(creator_tab > 1)
k_val <- min(10, max(3, floor(min_class_count / 5)))
imps <- make_imputations(df, M = M)
forms <- list(
M1 = bf(y ~ 1 + manual_label),
M2 = bf(y ~ 1 + manual_label + s(date_imp, k = k_val)),
M3 = bf(y ~ 1 + s(date_imp, k = k_val)),
M4 = bf(y ~ 1 + manual_label + s(date_imp, by = manual_label, k = k_val))
)
if (type_ok) {
forms$M5 <- bf(y ~ 1 + manual_label + type + s(date_imp, by = manual_label, k = k_val))
}
if (type_ok && creator_ok) {
forms$M6 <- bf(y ~ 1 + manual_label + type + s(date_imp, by = manual_label, k = k_val) + (1 | creator))
}
fits <- purrr::imap(
forms,
function(form, model_name) {
priors <- make_priors(form, imps[[1]])
brm_multiple(
formula = form,
data = imps,
family = student(),
prior = priors,
backend = "cmdstanr",
chains = M,       # Forces exactly 1 chain per imputation dataset
iter = 2000,      # Slightly lower iter works well since you have M=20 total chains now
warmup = 1000,
seed = 20260330,
refresh = 0,
control = list(adapt_delta = 0.99, max_treedepth = 13),
save_pars = save_pars(all = TRUE),
file = file.path("brms_fits", paste0(score_col, "_", model_name))
)
}
)
# moment_match = FALSE prevents cross-imputation crashes
fits <- purrr::map(fits, ~ add_criterion(.x, criterion = "loo", moment_match = FALSE))
loo_list <- purrr::map(fits, ~ .x$criteria$loo)
loo_tab <- loo_compare(loo_list) %>%
as.data.frame() %>%
tibble::rownames_to_column("model") %>%
as_tibble()
w <- loo_model_weights(loo_list, method = "stacking")
weights <- tibble(
model = names(w),
stacking_weight = as.numeric(w)
)
pairwise <- bind_rows(
elpd_diff_tbl(loo_list$M2, loo_list$M1, "M2", "M1"),
elpd_diff_tbl(loo_list$M2, loo_list$M3, "M2", "M3"),
elpd_diff_tbl(loo_list$M4, loo_list$M2, "M4", "M2"),
elpd_diff_tbl(loo_list$M5, loo_list$M4, "M5", "M4"),
elpd_diff_tbl(loo_list$M6, loo_list$M5, "M6", "M5")
)
best_name <- weights %>%
arrange(desc(stacking_weight)) %>%
slice(1) %>%
pull(model)
list(
data = df,
fits = fits,
forms = forms,
loo = loo_tab,
weights = weights,
pairwise = pairwise,
best_name = best_name,
best_fit = fits[[best_name]],
type_ok = type_ok,
creator_ok = creator_ok
)
}
results <- purrr::map(score_cols, ~ fit_one_score(.x, dat, M = 20))
